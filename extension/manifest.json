{
  "manifest_version": 3,
  "name": "Text Counter & Limits",
  "description": "Считает символы, символы без пробелов и слова. Подсвечивает превышение лимитов.",
  "version": "1.1.0",
  "permissions": [
    "contextMenus",
    "sidePanel",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Text Counter",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
